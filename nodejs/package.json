{
  "name": "nodejs",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "watch": "nodemon -w src -w config ./app.js",
    "start": "node ./app.js",
    "lint": "eslint . --ext .js,.mjs --report-unused-disable-directives --max-warnings 0",
    "prettier": "prettier --check .",
    "migration": "sequelize-cli migration:generate --name ",
    "undo-migration": "sequelize db:migrate:undo",
    "mig-all": "sequelize-cli db:migrate",
    "create-db": "sequelize db:create --charset utf8mb4 --collate utf8mb4_general_ci",
    "drop-db": "sequelize db:drop "
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mysql2": "^3.19.0",
    "nodemon": "^3.1.14",
    "sequelize": "^6.37.8",
    "yarn": "^1.22.22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "sequelize-cli": "^6.6.5"
  }
}
